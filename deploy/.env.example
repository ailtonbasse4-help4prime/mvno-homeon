# ========================
# MVNO Manager - Variaveis de Ambiente
# ========================
# Copie este arquivo para .env e preencha os valores

# ===== MONGODB =====
MONGO_URL=mongodb://mongo:27017
DB_NAME=mvno_management

# ===== SEGURANCA =====
# Gere uma chave forte: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=ALTERE_PARA_UMA_CHAVE_SECRETA_FORTE

# ===== TA TELECOM (Operadora MVNO) =====
USE_MOCK_API=false
TATELECOM_API_URL=http://sistema.tatelecom.com.br/api/public
TATELECOM_USER_TOKEN=SEU_TOKEN_AQUI
TATELECOM_TIMEOUT=30

# ===== ASAAS (Financeiro) =====
# Obtenha em: https://www.asaas.com/ -> Minha Conta -> Integrações -> API
# Sandbox: https://sandbox.asaas.com
ASAAS_API_KEY=
ASAAS_ENVIRONMENT=sandbox

# ===== DOMINIO (usado no nginx e CORS) =====
DOMAIN=seudominio.com.br
REACT_APP_BACKEND_URL=https://seudominio.com.br
